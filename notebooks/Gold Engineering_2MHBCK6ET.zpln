    {
      "text": "%spark\r\nimport org.apache.spark.sql.functions._\r\n\r\n// 1. Read from your \u0027cleaned\u0027 folder\r\nval cleanedPath \u003d \"/home/thedude/hazynet-lakehouse/cleaned\"\r\nval cleanedDF \u003d spark.read.parquet(cleanedPath)\r\n\r\n// 2. Aggregate to Customer Level (Gold Logic)\r\nval customerGoldDF \u003d cleanedDF.groupBy(\"full_name\")\r\n  .agg(\r\n    count(\"tx_id\").as(\"total_transactions\"),\r\n    sum(\"total_with_tax\").as(\"lifetime_spend\"),\r\n    avg(\"total_with_tax\").as(\"avg_transaction_value\"),\r\n    max(\"total_with_tax\").as(\"biggest_single_purchase\")\r\n  )\r\n  .withColumn(\"is_whale\", when(col(\"lifetime_spend\") \u003e 5000, 1.0f).otherwise(0.0f))\r\n\r\n// 3. Save to your \u0027gold\u0027 folder\r\nval goldPath \u003d \"/home/thedude/hazynet-lakehouse/gold/customer_profiles\"\r\ncustomerGoldDF.write.mode(\"overwrite\").parquet(goldPath)\r\n\r\nprintln(s\"SUCCESS: Gold Customer Profiles created at $goldPath\")\r\ncustomerGoldDF.orderBy(desc(\"lifetime_spend\")).show(5)",
