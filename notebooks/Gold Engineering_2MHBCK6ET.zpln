      "text": "%spark\r\nimport org.apache.spark.sql.functions._\r\nimport org.apache.spark.sql.types._\r\n\r\n// 1. Load the Gold Layer\r\nval goldPath \u003d \"/home/thedude/hazynet-lakehouse/gold/retail_sales_final\"\r\nval rawDF \u003d spark.read.parquet(goldPath)\r\n\r\n// 2. Align Features to ACTUAL columns found in your Parquet files\r\n// Based on error: [full_name, date_raw, city, state, tx_id, total_with_tax]\r\nval labelCol \u003d \"is_high_volume\"\r\nval featureCols \u003d Array(\"tx_id_float\", \"total_with_tax\")\r\n\r\nval engineeredDF \u003d rawDF\r\n  .withColumn(labelCol, when(col(\"total_with_tax\") \u003e 100, 1.0).otherwise(0.0))\r\n  .select(\r\n    col(labelCol).cast(DoubleType).as(labelCol),\r\n    col(\"tx_id\").cast(FloatType).as(\"tx_id_float\"),\r\n    col(\"total_with_tax\").cast(FloatType)\r\n  ).na.fill(0.0)\r\n\r\n// 3. Cache it in GPU Memory\r\nengineeredDF.cache()\r\nprintln(s\"Engineering Complete. ${engineeredDF.count()} rows ready on RTX 3060.\")\r\nengineeredDF.show(5)",
      "user": "anonymous",
