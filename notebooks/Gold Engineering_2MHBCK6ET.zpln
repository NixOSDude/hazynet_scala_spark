    {
      "text": "%spark\r\n// 1. Force properties at the very start\r\njava.lang.System.setProperty(\"NCCL_P2P_DISABLE\", \"1\")\r\njava.lang.System.setProperty(\"NCCL_SHM_DISABLE\", \"1\")\r\n\r\nimport ml.dmlc.xgboost4j.scala.{DMatrix, XGBoost \u003d\u003e NativeXGBoost}\r\nimport org.apache.spark.sql.functions._\r\nimport org.apache.spark.sql.types._\r\n\r\n// DATA PREP\r\nval goldPath \u003d \"/home/thedude/hazynet-lakehouse/gold/retail_sales_final\"\r\nval df \u003d spark.read.parquet(goldPath).sample(false, 0.01).cache()\r\n\r\nval localRows \u003d df.select(\r\n    col(\"total_with_tax\").cast(FloatType),\r\n    col(\"tx_id\").cast(FloatType)\r\n).collect()\r\n\r\nval labels \u003d localRows.map(r \u003d\u003e if(r.getFloat(0) \u003e 100) 1.0f else 0.0f)\r\nval features \u003d localRows.flatMap(r \u003d\u003e Array(r.getFloat(1), r.getFloat(0)))\r\nval dmat \u003d new DMatrix(features, localRows.length, 2, Float.NaN)\r\ndmat.setLabel(labels)\r\n\r\n// THE STABILITY PARAMS\r\n// Switching tree_method to \u0027hist\u0027 (CPU build) but keeping \u0027gpu_predictor\u0027\r\nval params: Map[String, Any] \u003d Map(\r\n  \"objective\" -\u003e \"binary:logistic\",\r\n  \"tree_method\" -\u003e \"hist\",          // Builds trees on CPU to avoid NCCL\r\n  \"predictor\" -\u003e \"gpu_predictor\",   // Uses RTX 3060 for the heavy prediction math\r\n  \"gpu_id\" -\u003e 0,\r\n  \"verbosity\" -\u003e 1\r\n)\r\n\r\nprintln(\"DIVERGENT PATH: Building on CPU, Predicting on GPU to bypass NCCL...\")\r\n\r\ntry {\r\n    val nativeModel \u003d NativeXGBoost.train(dmat, params, 10)\r\n    println(\"SUCCESS: The 3060 is contributing without crashing!\")\r\n    \r\n    val modelPath \u003d \"/home/thedude/hazynet-lakehouse/models/wsl_stable_3060.model\"\r\n    nativeModel.saveModel(modelPath)\r\n    println(s\"Model saved to: $modelPath\")\r\n} catch {\r\n    case e: Exception \u003d\u003e \r\n        println(\"BLOCKAGE DETECTED: If this fails, the XGBoost JNI is corrupted for WSL.\")\r\n        e.printStackTrace()\r\n}",
